# Force LF line endings — GitHub Actions YAML and Python files should not
# be CRLF, especially on Windows checkouts.
* text=auto eol=lf

# These types must always be LF regardless of platform
*.py          text eol=lf
*.yml         text eol=lf
*.yaml        text eol=lf
*.md          text eol=lf
*.sh          text eol=lf
*.toml        text eol=lf
*.cfg         text eol=lf
*.ini         text eol=lf

# Binary
*.png         binary
*.jpg         binary
*.gif         binary
*.ico         binary
*.pdf         binary
